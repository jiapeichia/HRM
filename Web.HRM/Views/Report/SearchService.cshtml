@model Meo.Web.ViewModels.EmployeeDetailsViewModel

@{
    ViewBag.Title = "Employee Service List";
    var ActiveList = ViewBag.ActiveList;
}
<head>
    <style>
        .customer-name {
            display: inline-block;
            vertical-align: middle;
            line-height: 32px;
            padding-left: 8px;
        }

        input.k-textbox {
            width: 100%;
            height: 2.45em;
            text-indent: .33em;
            line-height: 1.6em;
        }

        .k-textbox {
            max-width: 100%;
            width: 200px;
        }
    </style>

    @section Scripts {
        @Scripts.Render("~/bundles/jqueryval")

<script>
    $(function () {
        $('#today').click(function () {
            var empNo = $('#EmpNo').val();
            var url = "@Html.Raw(Url.Action("_SearchServiceReport", "Report", new { empNo = "empno", period = "today" }))";
            url = url.replace("empno", empNo.replace(" ", ""));
            $('#saveDiv').load(url);
        });

        $('#week').click(function () {
            var empNo = $('#EmpNo').val();
            var url = "@Html.Raw(Url.Action("_SearchServiceReport", "Report", new { empNo = "empno", period = "week" }))";
            url = url.replace("empno", empNo.replace(" ", ""));
            $('#saveDiv').load(url);
        });

        $('#month').click(function () {
            var empNo = $('#EmpNo').val();
            var url = "@Html.Raw(Url.Action("_SearchServiceReport", "Report", new { empNo = "empno", period = "month" }))";
            url = url.replace("empno", empNo.replace(" ", ""));
            $('#saveDiv').load(url);
        });

        $('#search').click(function () {
            var empNo = $('#EmpNo').val();
            var url = "@Html.Raw(Url.Action("_SearchServiceReport", "Report", new { empNo = "empno", period = "" }))";
            url = url.replace("empno", empNo.replace(" ", ""));
            $('#saveDiv').load(url);
        });

        $('#clear').click(function () {
            $("#EmpNo").val('').trigger("change");
            var url = "@Html.Raw(Url.Action("_SearchServiceReport", "Report", new { empNo = "" }))";
            $('#saveDiv').load(url);
        });

        $("#close").click(function () {
            window.open('@Url.Action("Index", "Home")', "_self");
        });
    });
        function error_handler(e) {
            if (e.errors) {
                var message = "Errors:\n";
                $.each(e.errors, function (key, value) {
                    if ('errors' in value) {
                        $.each(value.errors, function () {
                            message += this + "\n";
                        });
                    }
                });
                alert(message);
            }
        }

        function sync_handler(e) {
            this.read();
        }
</script>
    }
</head>
<div class="page-content">
    <table style="width:100%">
        <tr>
            <td>
                <h2 class="pagetitle">Employee Service Report</h2>
            </td>
            <td align="right">
                @(Html.Kendo().DropDownListFor(model => model.EmpNo)
                .Name("EmpNo")
                .BindTo((System.Collections.IEnumerable)ViewData["Employee"])
                .DataTextField("FullName").DataValueField("EmpNo")
                .OptionLabel(" -- Select Employee -- ")
                .Filter(FilterType.Contains))
            </td>
            <td align="right" style="width: 550px">
                <input type="button" value="SEARCH" class="btn btn-primary" id="search" style="width:100px" />
                <input type="button" value="TODAY" class="btn btn-primary" id="today" style="width:100px" />
                <input type="button" value="THIS WEEK" class="btn btn-primary" id="week" style="width:100px" />
                <input type="button" value="THIS MONTH" class="btn btn-primary" id="month" style="width:100px" />
                <input type="button" value="BACK" class="btn btn-default" id="close" style="width:100px" />
            </td>
        </tr>
    </table>
    <br />
    <div class="col-md-12" id="saveDiv">
        @{ Html.RenderAction("_SearchServiceReport", new { empNo = "", period = "" }); }
    </div>
</div>
