@model Meo.Web.ViewModels.PurchaseOrder

@{
    ViewBag.Title = "Stock Receive";
}

<head>
    <style>
        .customer-name {
            display: inline-block;
            vertical-align: middle;
            line-height: 32px;
            padding-left: 8px;
        }

        input.k-textbox {
            width: 100%;
            height: 2.45em;
            text-indent: .33em;
            line-height: 1.6em;
        }

        .k-textbox {
            max-width: 100%;
            width: 200px;
        }
    </style>

    @section Scripts {
        @Scripts.Render("~/bundles/jqueryval")

        <script>
    $(function () {
        $('#search').click(function () {
            var cusId = $('#SupplierId').val();
            var url = "@Html.Raw(Url.Action("_SeachStock", "Stock"))";
            url = url.replace("cusid", cusId.replace(" ", ""));
            $('#saveDiv').load(url);
        });

        $('#clear').click(function () {
            $("#SupplierId").val('').trigger("change");
            var url = "@Html.Raw(Url.Action("_SeachStock", "Stock"))";
            $('#saveDiv').load(url);
        });

        $("#close").click(function () {
            window.open('@Url.Action("Index", "Home")', "_self");
        });
    });

            function error_handler(e) {
                if (e.errors) {
                    var message = "Errors:\n";
                    $.each(e.errors, function (key, value) {
                        if ('errors' in value) {
                            $.each(value.errors, function () {
                                message += this + "\n";
                            });
                        }
                    });
                    alert(message);
                }
            }

            function sync_handler(e) {
                this.read();
            }
        </script>
    }
</head>
<div class="page-content">
    <table style="width:100%">
        <tr>
            <td>
                <h2 class="pagetitle">Stock Receive</h2>
            </td>
            <td align="right">
                @*@(Html.Kendo().DropDownListFor(model => model.SupplierId)
                        .Name("supId")
                        .BindTo((System.Collections.IEnumerable)ViewData["Supplier"])
                        .DataTextField("Name").DataValueField("Id")
                        .OptionLabel(" ------- Select ------- ")
                        .Filter(FilterType.Contains))

                @Html.TextBox("SearchContent", "", new { @class = "k-textbox fa fa-search", @style = "width: 350px", @placeholder = HttpUtility.HtmlDecode("&#xf002;") + " Search By Customer info" })*@
            </td>
            <td align="right" style="width: 230px">
                @*<input type="button" value="SEARCH" class="btn btn-primary" id="search" style="width:100px" />*@
                <input type="button" value="BACK" class="btn btn-default" id="close" style="width:100px" />
            </td>
        </tr>
    </table>
    <br />
    <div class="col-md-12" id="saveDiv">
        @{ Html.RenderAction("_SearchStock", new { id = "" }); }
    </div>
</div>
