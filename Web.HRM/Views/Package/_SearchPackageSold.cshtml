@using Meo.Web.ViewModels

@(Html.Kendo().Grid<PackageSoldViewModels>()
    .Name("GridForPackageSold")
    .HtmlAttributes("100%")
    .Columns(columns =>
    {
        //columns.Bound(c => c.CusId).Title("").ClientTemplate(
        //"# if (data.ImagePath != null) { #"
        //+ "<div class='small-photo' style='background-image: url(" + @Url.Content("~/Images/Customer/#:data.ImagePath#") + ");'></div>"
        //+ "# } else { #"
        //+ "<div class='small-photo' style='background-image: url(" + @Url.Content("~/Images/Customer/user.png") + ");'></div>"
        //+ "# } #"
        //+ "<div class='customer-name'></div>").Width("50px");
        columns.ForeignKey(c => c.CusId, (System.Collections.IEnumerable)ViewData["Customer"], "CusId", "FullName").Title("Customer");
        columns.Bound(c => c.PackageCode);
        columns.Bound(c => c.PackageRemarks);
        columns.Bound(c => c.TotalCost);
        columns.Bound(c => c.SellingPrice);
        columns.Bound(c => c.Active).ClientTemplate("# if (Active == false) { #" +
           "Active" +
       "# } else if (Active == true) { #" +
           "Inactive" +
       "# } else { #" +
       "# } #"
       ).Width("80px");
        columns.Bound(c => c.ModDate).ClientTemplate("#= kendo.toString(ModDate, 'd') #");
    })
    .Pageable(pageable => pageable
    .Refresh(true).Messages(m => m.Refresh(string.Empty)))
    //.Events(e => e.Edit("onRequest"))
    .Sortable()
    .Resizable(resize => resize.Columns(true))
    .DataSource(dataSource => dataSource
    .Ajax()
    .PageSize(10)
    //.Events(events => events.Error("error_handler").Sync("sync_handler").RequestEnd("onRequestEnd"))
    .ServerOperation(true)
    .Read(read => read.Action("Read_PackageSold", "Package", new { searchContent = ViewBag.searchContent }))
    .Model(modelItem =>
    {
        modelItem.Id(e => e.Id);
    })
    ).NoRecords("No Records Found")
    )

<span id="notification" style="display:none;"></span>
@* Error msg to be shown & sync grid table automatically *@
<script type="text/javascript">
    function error_handler(e) {
        if (e.errors) {
            var message = "Errors:\n";
            $.each(e.errors, function (key, value) {
                if ('errors' in value) {
                    $.each(value.errors, function () {
                        message += this + "\n";
                    });
                }
            });
            alert(message);
        }
    }

    function sync_handler(e) {
        this.read();
    }

    $(".close-button").click(function () {
        window.open('@Url.Action("Index", "Home")', "_self");
    });
</script>
