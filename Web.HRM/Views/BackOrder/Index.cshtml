@model Meo.Web.ViewModels.CustomerDetailsViewModel

@{
    ViewBag.Title = "Back Order List";
    var ActiveList = ViewBag.ActiveList;
}
<head>
    <style>
        .customer-name {
            display: inline-block;
            vertical-align: middle;
            line-height: 32px;
            padding-left: 8px;
        }

        input.k-textbox {
            width: 100%;
            height: 2.45em;
            text-indent: .33em;
            line-height: 1.6em;
        }

        .k-textbox {
            max-width: 100%;
            width: 200px;
        }

        /* green count */
        .green-count {
            background-color: green;
            width: 25px;
            height: 25px;
            border-radius: 50%;
            text-align: center;
            color: white;
            font-weight: bold;
            box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.2);
        }
    </style>

    <script>
        $(function () {
            $('#search').click(function () {
            let searchContent = $('#SearchContent').val().trim();

            let url1 = '@Url.Action("_SearchBackOrder", "BackOrder")';
            let url2 = '@Url.Action("_SearchPreOrder", "BackOrder")';

            $('#backOrderDiv').load(url1, { searchContent: searchContent });
            $('#preOrderDiv').load(url2, { searchContent: searchContent });
        });

        $('#clear').click(function () {
            $("#SearchContent").val('').trigger("change");

            let url1 = '@Url.Action("_SearchBackOrder", "BackOrder")';
            let url2 = '@Url.Action("_SearchPreOrder", "BackOrder")';

            $('#backOrderDiv').load(url1);
            $('#preOrderDiv').load(url2);
        });

         $('#newbo').click(function () {
             $("#SearchContent").val('').trigger("change");
             window.open('@Url.Action("BackOrderSales", "BackOrder", new { flag = "new" })', "_self");
         });

        $("#close").click(function () {
            window.open('@Url.Action("Index", "Home")', "_self");
        });
    });

    function error_handler(e) {
        if (e.errors) {
            var message = "Errors:\n";
            $.each(e.errors, function (key, value) {
                if ('errors' in value) {
                    $.each(value.errors, function () {
                        message += this + "\n";
                    });
                }
            });
            alert(message);
        }
    }

    function sync_handler(e) {
        this.read();
    }
    </script>
</head>
<div class="page-content">
    <table style="width:100%">
        <tr>
            <td>
                <h2 class="pagetitle">Back Order List</h2>
            </td>
            <td align="right">
                @Html.TextBox("SearchContent", "", new { @class = "k-textbox fa fa-search", @style = "width: 350px", @placeholder = HttpUtility.HtmlDecode("&#xf002;") + " Search By Customer info" })
            </td>
            <td align="right" style="width:450px">
                <input type="button" value="SEARCH" class="btn btn-primary" id="search" style="width:100px" />
                <input type="button" value="CLEAR" class="btn btn-primary" id="clear" style="width:100px" />
                <input type="button" value="NEW" class="btn btn-success" id="newbo" style="width:100px" />
                <input type="button" value="BACK" class="btn btn-default" id="close" style="width:100px" />
            </td>
        </tr>
    </table>
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
                 alert('@TempData["ErrorMessage"]');
        </script>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    <hr />
    <div id="backOrderDiv">
        @{ Html.RenderAction("_SearchBackOrder", new { searchContent = "" }); }
    </div>
    <br />

    <h2 class="pagetitle">Pre Order List</h2>
    <div id="preOrderDiv">
        @{ Html.RenderAction("_SearchPreOrder", new { searchContent = "" }); }
    </div>
</div>

