@model Meo.Web.Model.UserLoginModel

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <meta charset="utf-8" />
    <title>Login</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" />
    <link rel="stylesheet" type="text/css" href="http://codeseven.github.com/toastr/toastr.css">
    <link href="~/Content/animate.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/site.css" rel="stylesheet" type="text/css" />

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body, html {
            width: 100%;
            height: 100%;
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #d4d4d4 0%, #808080 50%, #646464 100%);
            min-height: 100vh;
            position: relative;
            overflow: hidden;
        }

            /* Animated background elements - subtle and transparent */
            body::before {
                content: '';
                position: fixed;
                width: 500px;
                height: 500px;
                background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, rgba(255, 255, 255, 0) 70%);
                border-radius: 50%;
                top: -150px;
                left: -150px;
                animation: float 8s ease-in-out infinite;
                z-index: 1;
            }

            body::after {
                content: '';
                position: fixed;
                width: 400px;
                height: 400px;
                background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0) 70%);
                border-radius: 50%;
                bottom: -100px;
                right: -100px;
                animation: float 10s ease-in-out infinite reverse;
                z-index: 1;
            }

        @@keyframes float {
            0%, 100% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(20px);
            }
        }

        .container {
            position: relative;
            z-index: 2;
            width: 100%;
            display: flex;
            justify-content: center;
            padding: 20px;
        }

        .card-container.card {
            width: 100%;
            max-width: 420px;
            padding: 60px 45px;
            background: rgba(255, 255, 255, 0.92);
            border-radius: 20px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.25), 0 10px 30px rgba(0, 0, 0, 0.15);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            animation: slideIn 0.6s ease-out;
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .card-container h1 {
            text-align: center;
            font-size: 2em;
            color: #444;
            margin-bottom: 30px;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .logo {
            display: flex;
            justify-content: center;
            margin-bottom: 0px;
        }

            .logo img {
                width: 250px;
                height: auto;
               /* border-radius: 12px;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);*/
            }

        .divider {
            height: 2px;
            background: linear-gradient(to right, transparent, silver 20%, silver 80%, transparent);
            margin: 20px 0 30px 0;
        }

        .form-signin {
            display: flex;
            flex-direction: column;
        }

        .form-group {
            margin-bottom: 20px;
            position: relative;
        }

        .form-signin input[type=email],
        .form-signin input[type=password],
        .form-signin input[type=text] {
            width: 100%;
            padding: 14px 16px;
            font-size: 15px;
            border: 2px solid #d0d0d0;
            border-radius: 8px;
            transition: all 0.3s ease;
            font-family: inherit;
            background-color: rgba(248, 248, 248, 0.8);
            color: #333;
        }

            .form-signin input[type=email]:focus,
            .form-signin input[type=password]:focus,
            .form-signin input[type=text]:focus {
                outline: none;
                border-color: #999;
                background-color: #fff;
                box-shadow: 0 0 0 3px rgba(153, 153, 153, 0.1);
            }

        .form-signin input::placeholder {
            color: #888;
            font-weight: 500;
        }

        /* Button styles */
        .container-login100-form {
            width: 100%;
            display: flex;
            justify-content: center;
            padding-top: 10px;
            margin-top: 10px;
        }

        .login100-form-btn {
            font-family: inherit;
            font-size: 15px;
            font-weight: 600;
            line-height: 1.5;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 1px;
            width: 100%;
            height: 50px;
            border-radius: 8px;
            background: linear-gradient(135deg, #8b8b8b 0%, #5a5a5a 100%);
            border: none;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 0 25px;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
            position: relative;
            overflow: hidden;
        }

            .login100-form-btn:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
                background: linear-gradient(135deg, #6a6a6a 0%, #424242 100%);
            }

            .login100-form-btn:active {
                transform: translateY(-1px);
            }

            .login100-form-btn:disabled {
                opacity: 0.6;
                cursor: not-allowed;
                transform: none;
            }

            /* Loading state */
            .login100-form-btn.loading {
                pointer-events: none;
            }

                .login100-form-btn.loading::after {
                    content: '';
                    position: absolute;
                    width: 16px;
                    height: 16px;
                    top: 50%;
                    left: 50%;
                    margin-left: -8px;
                    margin-top: -8px;
                    border: 2px solid rgba(255, 255, 255, 0.3);
                    border-radius: 50%;
                    border-top-color: #fff;
                    animation: spinner 0.6s linear infinite;
                }

        @@keyframes spinner {
            to {
                transform: rotate(360deg);
            }
        }

        /* Validation styles */
        .validation-summary-errors {
            background-color: #fff5f5;
            border: 1px solid #daa;
            border-left: 4px solid #c33;
            color: #944;
            padding: 15px;
            border-radius: 6px;
            margin-bottom: 20px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
        }

            .validation-summary-errors::before {
                content: '⚠';
                font-size: 20px;
                font-weight: bold;
                flex-shrink: 0;
            }

            .validation-summary-errors ul {
                list-style: none;
                margin: 0;
            }

            .validation-summary-errors li {
                margin: 4px 0;
            }

        /* Helper links */
        .login-helpers {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 20px;
            font-size: 13px;
        }

            .login-helpers a {
                color: #777;
                text-decoration: none;
                transition: all 0.3s ease;
                font-weight: 500;
            }

                .login-helpers a:hover {
                    color: #333;
                    text-decoration: underline;
                }

        /* Responsive design */
        @@media (max-width: 768px) {
            .card-container.card {
                padding: 40px 30px;
                max-width: 90%;
            }

            .card-container h1 {
                font-size: 1.6em;
            }

            .logo img {
                width: 100px;
            }
        }

        @@media (max-width: 480px) {
            body, html {
                padding: 10px;
            }

            .card-container.card {
                padding: 30px 20px;
            }

            .form-signin input[type=email],
            .form-signin input[type=password],
            .form-signin input[type=text] {
                padding: 12px 14px;
                font-size: 14px;
            }

            .login100-form-btn {
                height: 48px;
                font-size: 14px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card card-container">
            <a class="logo"><img src="~/Images/logo.png" alt="Logo" /></a>
            <div class="divider"></div>

            @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { id = "login-form", @class = "form-signin" }))
            {
                @Html.AntiForgeryToken()

                if (ViewBag.LoginFailed != null)
                {
                    <div class="validation-summary-errors">
                        <ul>
                            <li>@ViewBag.LoginFailed</li>
                        </ul>
                    </div>
                }

                <div class="form-group">
                    @Html.TextBoxFor(m => m.username,
                                  new
                                  {
                                      @class = "form-control",
                                      @type = "text",
                                      @placeholder = "Username",
                                      @autofocus = "autofocus",
                                      autocomplete = "username",
                                      @Value = "system"
                                  })
                </div>

                <div class="form-group">
                    @Html.PasswordFor(m => m.Password,
                                  new
                                  {
                                      @class = "form-control",
                                      @placeholder = "Password",
                                      autocomplete = "current-password",
                                      @Value = "system"
                                  })
                </div>

                <div class="container-login100-form">
                    <button class="login100-form-btn" autocomplete="off" id="btnLogin" type="submit">Login</button>
                </div>

                <div class="login-helpers">
                    <a href="@Url.Action("ForgetPassword", "Account")">Forgot Password?</a>
                    <a href="@Url.Action("ForgetPassword", "Account")">First time login?</a>
                </div>
            }
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-1.10.2.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('#btnLogin').on('click', function () {
                $(this).addClass('loading');
            });

            $('#login-form').on('submit', function () {
                $('#btnLogin').prop('disabled', true).addClass('loading');
            });
        });
    </script>
</body>
</html>