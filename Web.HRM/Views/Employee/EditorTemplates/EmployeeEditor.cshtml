@model Meo.Web.ViewModels.EmployeeDetailsViewModel

@using Kendo.Mvc.UI;

@{
    ViewBag.Title = "Manage Employee List";
}
@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script src="~/Scripts/jquery-1.7.1.min.js" type="text/javascript"></script>
    <script src="~/Scripts/jquery.validate.min.js" type="text/javascript"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js" type="text/javascript"></script>
}

<form>
    <div style="padding-left:10px;padding-right:10px;padding-bottom:10px">
        <div style="padding-left:10px;padding-right:10px;padding-bottom:10px">
            <fieldset>
                <legend>Employee Info</legend>
                <table style="width:100%">
                    <tr>
                        <td rowspan="2" width="10%" align="center">
                            <img src="@Url.Content("~/UserImage/" + Model.ImagePath)" padding="5px" width="110" height="130" alt="" onerror="this.src='@Url.Content("~/UserImage/user.png")' " /><br>
                            @*<img src="~/UserImage/${data.ImagePath}" padding="5px" width="100" height="100" alt="StaffImage" onerror="this.src='@Url.Content("~/UserImage/user.png")' " />*@<br>

                        </td>
                        <td style="width:5%">@Html.LabelFor(model => model.EmpNo, new { @style = "width : 150px" })</td>
                        <td style="width:30%">
                            @Html.EditorFor(model => model.EmpNo)
                            @Html.ValidationMessageFor(model => model.EmpNo)
                        </td>
                        <td style="width:5%">
                            @Html.LabelFor(model => model.FullName, new { @style = "width : 150px" })
                        </td>
                        <td style="width:30%">
                            @Html.EditorFor(model => model.FullName, new { @style = "width : 350px" })
                            @Html.ValidationMessageFor(model => model.FullName)
                        </td>
                    </tr>
                    <tr>
                        <td>
                            @Html.LabelFor(model => model.HiredDate, new { @style = "width : 150px", required = "required" })
                        </td>
                        <td>
                            <input type="text" data-role='datepicker' id="HiredDate" name="HiredDate" data-type="date" required="required" />@*<span id="result"></span>*@
                            @*@Html.Kendo().DatePickerFor(model => model.HiredDate)*@
                            @*@(Html.Kendo().DatePickerFor(model => model.HiredDate)
                                .Culture("en-IE")
                                .Format("dd/MM/yyyy")
                                .ParseFormats(new List<string>() { "dd/MM/yyyy" })
                                .HtmlAttributes(new { id = "HiredDate" }))*@

                            @Html.ValidationMessageFor(model => model.HiredDate)
                        </td>
                        <td>@Html.LabelFor(model => model.DisplayName, new { @style = "width : 150px" })</td>
                        <td>
                            @Html.EditorFor(model => model.DisplayName, new { @style = "width : 350px" })
                            @Html.ValidationMessageFor(model => model.DisplayName)
                        </td>
                    </tr>
                    <tr>
                        <td align="center">
                            @(Html.Kendo().Upload()
.Name("file")
.HtmlAttributes(new { accept = "image/*" })
.Multiple(false)
                            )
                            @*<input name="file" id="files-jpg" type="file" />
                                <div class="demo-hint"><i><strong>GIF</strong>, <strong>JPG</strong>, <strong>PNG</strong> files ONLY</i></div>*@
                            <div style="display:none">
                                @Html.EditorFor(model => model.ImagePath, new { @style = "width : 100px" })

                            </div>
                        </td>
                        <td>@Html.LabelFor(model => model.Gender, new { @style = "width : 150px" })</td>
                        <td>
                            Male @Html.RadioButtonFor(m => m.Gender, "Male", new { @style = "width : 40px" })
                            Female @Html.RadioButtonFor(m => m.Gender, "Female", new { @style = "width : 40px" })

                            @Html.ValidationMessageFor(model => model.Gender)
                        </td>
                        <td>
                            @Html.LabelFor(model => model.OEmail, new { @style = "width : 150px" })
                        </td>
                        <td>
                            @Html.EditorFor(model => model.OEmail, new { @style = "width : 450px" })
                            @Html.ValidationMessageFor(model => model.OEmail)
                        </td>
                    </tr>
                </table>
            </fieldset>
        </div>

        @* content for Collaspe *@
        <div style="padding:10px">
            <fieldset>
                <legend>Department Info</legend>
                <table style="width:100%">
                    <tr>
                        <td width="10%"></td>
                        <td style="width:5%">
                            @Html.Label("Department", new { @style = "width : 150px" })
                        </td>
                        <td style="width:30%">
                            @Html.Kendo().DropDownListFor(model => model.Dept_id).BindTo((System.Collections.IEnumerable)ViewData["Department"]).DataTextField("Dept_name").DataValueField("Dept_id").OptionLabel("Select Department").SelectedIndex(0).Filter(FilterType.Contains)
                            @Html.ValidationMessageFor(model => model.Dept_id)
                        </td>
                        <td style="width:5%">
                            @Html.LabelFor(model => model.Manager1st_id, new { @style = "width : 150px" })
                        </td>
                        <td style="width:30%">
                            @Html.Kendo().DropDownListFor(model => model.Manager1st_id).BindTo((System.Collections.IEnumerable)ViewData["Employee_List"]).DataTextField("DisplayName").DataValueField("Emp_id").OptionLabel("Select Manager").Filter(FilterType.Contains)
                            @Html.ValidationMessageFor(model => model.Manager1st_id)
                        </td>
                    </tr>
                    <tr>
                        <td width="10%"></td>
                        <td>@Html.LabelFor(model => model.JobTitle_id, new { @style = "width : 150px" })</td>
                        <td>
                            @Html.Kendo().DropDownListFor(model => model.JobTitle_id).BindTo((System.Collections.IEnumerable)ViewData["JobTitle"]).DataTextField("JobTitle_name").DataValueField("JobTitle_id").OptionLabel("Select Job Title").SelectedIndex(0).Filter(FilterType.Contains)
                            @Html.ValidationMessageFor(model => model.JobTitle_id)
                        </td>
                        <td>@Html.LabelFor(model => model.Country_id, new { @style = "width : 150px" })</td>
                        <td>
                            @Html.Kendo().DropDownListFor(model => model.Country_id).BindTo((System.Collections.IEnumerable)ViewData["Country"]).DataTextField("Country_name").DataValueField("Country_id").OptionLabel("Select Country").SelectedIndex(0).Filter(FilterType.Contains)
                            @Html.ValidationMessageFor(model => model.Country_id)
                        </td>
                    </tr>
                    <tr>
                        <td width="10%"></td>
                        <td style="width:5%"></td>
                        <td style="width:30%"></td>
                        <td style="width:5%">
                            @Html.LabelFor(model => model.Manager2nd_id, new { @style = "width : 150px" })
                        </td>
                        <td style="width:30%">
                            @Html.Kendo().DropDownListFor(model => model.Manager2nd_id).BindTo((System.Collections.IEnumerable)ViewData["Employee_List"]).DataTextField("DisplayName").DataValueField("Emp_id").OptionLabel("Select Manager").Filter(FilterType.Contains)
                            @Html.ValidationMessageFor(model => model.Manager2nd_id)
                        </td>
                    </tr>
                </table>
            </fieldset>
        </div>

        @* ------------  Confirm/Termination ----------- *@
        <div style="padding:10px">
            <fieldset>
                <legend>Confirm/Termination</legend>
                <table style="width:100%">
                    <tr>
                        <td width="10%"></td>
                        <td style="width:5%">
                            @Html.LabelFor(model => model.ProbationPeriod_id, new { @style = "width : 150px" })
                        </td>
                        <td style="width:30%">
                            @Html.Kendo().DropDownListFor(model => model.ProbationPeriod_id).BindTo((System.Collections.IEnumerable)ViewData["ProbationPeriod"]).DataTextField("ProbationPeriod_name").DataValueField("ProbationPeriod_id").OptionLabel("Select Probation Period").SelectedIndex(0)
                            @Html.ValidationMessageFor(model => model.ProbationPeriod_id)
                        </td>
                        <td style="width:5%">
                            @Html.LabelFor(model => model.ConfirmationDate, new { @style = "width : 150px" })
                        </td>
                        <td style="width:30%">
                            @*<input id="ConfirmationDate" />*@
                            @*@Html.Kendo().DatePickerFor(model => model.ConfirmationDate)*@
                            @(Html.Kendo().TextBoxFor(model => model.ConfirmationDate)
                                                       .Enable(false))
                            @*@Html.Kendo().TextBoxFor(model => model.ConfirmationDate).Format("dd/MM/yyyy").Enable(false)*@
                            @Html.ValidationMessageFor(model => model.ConfirmationDate)
                        </td>
                    </tr>
                    @*<tr>
                                            <td width="10%"></td>
                                            <td>@Html.LabelFor(model => model.ResignationDate, new { @style = "width : 150px" })</td>
                                            <td>
                                                @(Html.Kendo().DatePickerFor(model => model.ResignationDate)
                        .Culture("en-IE")
                        .Format("dd/MM/yyyy")
                        .ParseFormats(new List<string>() { "dd/MM/yyyy" })
                        .HtmlAttributes(new { @class = "form-control" }))
                                                @Html.Kendo().DatePickerFor(model => model.ResignationDate)
                                                @Html.ValidationMessageFor(model => model.ResignationDate)
                                            </td>
                                            <td>@Html.LabelFor(model => model.EmpStatus_id, new { @style = "width : 150px" })</td>
                                            <td>
                                                @Html.Kendo().DropDownListFor(model => model.EmpStatus_id).BindTo((System.Collections.IEnumerable)ViewData["EmployeeStatus"]).DataTextField("EmployeeStatu_names").DataValueField("EmployeeStatus_id").OptionLabel("Select Probation Period").Enable(false)
                                                @Html.ValidationMessageFor(model => model.EmpStatus_id)
                                            </td>
                                        </tr>*@
                </table>
            </fieldset>
        </div>
    </div>

    @*var todayDate = new Date(Date.now());
        if (todayDate < confirmDate) {
            $("#EmpStatus_id").val(1).trigger("change");
        }*@
</form>
<script>

    $(document).ready(function () {

        $("#HiredDate").kendoDatePicker({
            format: "dd/MM/yyyy", parseFormats: ["dd/MM/yyyy"]
        }).data("kendoDatePicker");

        $("#HiredDate").change(function () {
            var hd = $("#HiredDate").val();
            var hiredDate = new Date(kendo.parseDate(hd, "dd/MM/yyyy"));
            var date1 = kendo.parseDate(hiredDate, 'd');
            var probation = $("#ProbationPeriod_id").data("kendoDropDownList").text();

            if (probation != "" && (probation == "3 + 3 Months" || probation == "6 Months")) {
                var confirmDate = new Date(date1.setMonth(date1.getMonth() + 6));
            } else {
                var confirmDate = new Date(date1.setMonth(date1.getMonth() + 3));
            }

            var cDate = kendo.toString(kendo.parseDate(confirmDate), 'dd/MM/yyyy');
            var HD = kendo.toString(kendo.parseDate(hiredDate), 'dd/MM/yyyy');

            $("#ConfirmationDate").val(cDate).trigger("change").text.format('dd/MM/yyyy');
            $("#HiredDate").val(HD).trigger("change").text.format('dd/MM/yyyy');
        });

        $("#ProbationPeriod_id").change(function () {
            var hd = $("#HiredDate").val();
            var hiredDate = new Date(kendo.parseDate(hd, "dd/MM/yyyy"));
            var date1 = kendo.parseDate(hiredDate, 'd');
            var probation = $("#ProbationPeriod_id").data("kendoDropDownList").text();

            var HD = kendo.toString(kendo.parseDate(hiredDate), 'dd/MM/yyyy');

            if (probation != "" && (probation == "3 + 3 Months" || probation == "6 Months")) {
                var confirmDate = new Date(date1.setMonth(date1.getMonth() + 6));
            } else {
                var confirmDate = new Date(date1.setMonth(date1.getMonth() + 3));
            }
            var cDate = kendo.toString(kendo.parseDate(confirmDate), 'dd/MM/yyyy');

            $("#ConfirmationDate").val(cDate).trigger("change").text(cDate);
            $("#HiredDate").val(HD).trigger("change").text.format('dd/MM/yyyy');
        });


    });

</script>
<style>
    legend {
        padding: 0.2em 0.5em;
        color: grey;
        font-size: 130%;
    }

    fieldset {
        border: 1px solid grey;
        padding: 1em;
        font: 100%/1 sans-serif;
    }

    label {
        float: left;
        width: 25%;
        margin-right: 0.5em;
        padding-top: 0.2em;
        text-align: right;
        font-weight: bold;
    }

    td {
        padding: 5px;
    }

    .k-upload .k-upload-button {
        min-width: 7.167em;
        margin-right: 0em;
    }

    .k-dropzone {
        border-style: solid;
        border-width: 0;
        padding: .2em;
        background-color: white;
    }

    .k-dropdown, .k-textbox {
        /*width: 100%;*/
        max-width: 100%;
        width: 18.4em;
    }
</style>


