@model Meo.Web.ViewModels.PunchCardViewModels
@using Kendo.Mvc.UI;

@{
    ViewBag.Title = "Punch Card";
}

<head>
    @Styles.Render("~/Content/css")
    <link href="https://kendo.cdn.telerik.com/2017.3.1026/styles/kendo.common.min.css" rel="stylesheet" type="text/css" />
    <link href="https://kendo.cdn.telerik.com/2017.3.1026/styles/kendo.mobile.all.min.css" rel="stylesheet" type="text/css" />
    <link href="https://kendo.cdn.telerik.com/2017.3.1026/styles/kendo.default.min.css" rel="stylesheet" type="text/css" />
    <script src="https://kendo.cdn.telerik.com/2017.3.1026/js/jquery.min.js"></script>
    <script src="https://kendo.cdn.telerik.com/2017.3.1026/js/jszip.min.js"></script>
    <script src="https://kendo.cdn.telerik.com/2017.3.1026/js/kendo.all.min.js"></script>
    <script src="https://kendo.cdn.telerik.com/2017.3.1026/js/kendo.aspnetmvc.min.js"></script>
</head>
<body>
    @using (Html.BeginForm("Update_PunchCard", "Employee", FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
    {
        @Html.HiddenFor(m => m.Date)
        <div class="card px-0 pt-4 pb-0 mt-3 mb-3" style="text-align: center">
            <table>
                <tbody>
                    <tr>
                        <td>
                            @Html.LabelFor(model => model.ClockIn, new { @style = "width : 250px", @class = "control-label col-md-2" })
                        </td>
                        <td>
                            @(Html.Kendo().DatePickerFor(model => model.ClockIn)
                            .Culture("en-IE")
                            .Format("dd/MM/yyyy")
                            .ParseFormats(new List<string>() { "dd-MMM-yyyy" })
                            .HtmlAttributes(new { @class = "form-control" }).Enable(false))
                            @Html.ValidationMessageFor(model => model.ClockIn, "", new { @class = "text-danger" })
                        </td>
                    </tr>
                    <tr>
                        <td>
                            @Html.LabelFor(model => model.EmpNo, new { @style = "width : 250px", @class = "control-label col-md-2" })
                        </td>
                        <td>
                            @(Html.Kendo().DropDownListFor(model => model.EmpNo)
                            .BindTo((System.Collections.IEnumerable)ViewData["Employee"])
                            .DataTextField("FullName").DataValueField("EmpNo").Filter(FilterType.Contains))
                            @Html.ValidationMessageFor(model => model.EmpNo)
                        </td>
                    </tr>
                </tbody>
            </table>
            <br />
            <span style="padding-right:5px"><button id="update" data-bind="click: update; close;" class="btn btn-success" style="width: 200px; padding: 5px">CONFRIM</button></span>
            @*<input type="button" value="CONFRIM" class="btn btn-success" id="update" data-bind="click: update" style="width:200px" />*@
            <input type="button" value="CANCEL" class="btn btn-default" style="width:200px" onclick="window.opener=null; window.close(); return false;" />
        </div>
    }

</body>
