@model Meo.Web.ViewModels.SupplierViewModels
<head>
    @section Scripts {
        @Scripts.Render("~/bundles/jqueryval")

        <script>
        function error_handler(e) {
            if (e.errors) {
                var message = "Errors:\n";
                $.each(e.errors, function (key, value) {
                    if ('errors' in value) {
                        $.each(value.errors, function () {
                            message += this + "\n";
                        });
                    }
                });
                alert(message);
            }
        }

        function sync_handler(e) {
            this.read();
        }

        $(".close-button").click(function () {
            window.open('@Url.Action("Index", "Home")', "_self");
            //window.close();
        });

        // --- collapse all group grid ---
        var collapseAllGroups = function (grid) {
            grid.table.find(".k-grouping-row").each(function () {
                grid.collapseGroup(this);
            });
        }

        //On the grid
        function dataBound() {
            collapseAllGroups(this);
        }
        </script>
    }
</head>
<div>
    @(Html.Kendo().Grid<Meo.Web.ViewModels.SupplierViewModels>()
        .Name("GridForSupplier")
        .HtmlAttributes(new { style = "100%" })
        .Columns(columns =>
        {
            columns.Bound(c => c.SupplierId);
            columns.Bound(c => c.Name);
            columns.Bound(c => c.ContactNo);
            columns.Bound(c => c.ContactNo2);
            columns.Bound(c => c.Address1);
            columns.Bound(c => c.Address2);
            columns.Command(command => { command.Edit(); }).Width(90);
            if (Session["RoleName"].Equals("Administrator") || Session["RoleName"].Equals("SuperAdmin"))
            {
                columns.Command(command => command.Destroy()).Width(90);
            }
        })
        .Sortable()
        .Pageable(pageable => pageable
        .Refresh(true).Messages(m => m.Refresh(string.Empty)))
        .Editable(editable => editable.Mode(GridEditMode.PopUp).TemplateName("SupplierEditor"))
        .ToolBar(toolbar => toolbar.Template("<a id='Create' class='k-button k-button-icontext k-grid-add' href='#'> + Create New </a>"))
        //.ToolBar(toolbar => toolbar.Template("<a id='Create' class='k-button k-button-icontext k-add' href='" + @Url.Action("NewSupplier", "Supplier") + "'style='float:right'> + Create New </a>"))
        .DataSource(source => source
        .Ajax()
        .PageSize(10)
        .Events(events => events.Error("error_handler").Sync("sync_handler").RequestEnd("onRequestEnd"))
        .Sort(sort => sort.Add("Name").Ascending())
        .Model(model =>
        {
            model.Id(tc => tc.SupplierId);
        })
        .Read(read => read.Action("GetSearchData", "Supplier", new { searchContent = ViewBag.searchContent }))
        .Create(update => update.Action("Create_Supplier", "Supplier"))
        .Update(update => update.Action("Update_Supplier", "Supplier"))
        .Destroy(update => update.Action("Destroy_Supplier", "Supplier"))
        )
        //.Resizable(resize => resize.Columns(true))
        .NoRecords("No Records Found")
    )
</div>
<span id="notification" style="display:none;"></span>

<script type="text/javascript">
    function onRequestEnd(e) {
        var notificationWidget = $("#notification").kendoNotification(
            {
                position: {
                    pinned: true,
                    top: 100,
                    right: 50
                },
            }).data("kendoNotification");

        if (e.type == "create" && !e.response.Errors) {
            notificationWidget.show("New Record created!", "success");
        } else if (e.type == "update" && !e.response.Errors) {
            notificationWidget.show("Update Successfully", "success");
        } else if (e.response.Errors) {
            notificationWidget.show("Fail to update", "warning");
        }
    }
</script>