@*@model IEnumerable<Meo.Web.ViewModels.SupplierDetailsViewModel>*@
@model Meo.Web.ViewModels.SupplierViewModels

@{
    ViewBag.Title = "Supplier List";
    var ActiveList = ViewBag.ActiveList;
}
    <head>
    <style>
        .customer-name {
            display: inline-block;
            vertical-align: middle;
            line-height: 32px;
            padding-left: 8px;
        }

        input.k-textbox {
            width: 100%;
            height: 2.45em;
            text-indent: .33em;
            line-height: 1.6em;
        }

        .k-textbox {
            max-width: 100%;
            width: 200px;
        }
    </style>

<script>
    $(function () {
        $('#search').click(function () {
            var searchContent = $('#SearchContent').val();
            var url = "@Html.Raw(Url.Action("_SearchSupplier", "Supplier", new { searchContent = "searchcontent" }))";
            url = url.replace("searchcontent", searchContent.replace(" ", ""));
            $('#saveDiv').load(url);
        });

        $('#clear').click(function () {
            $("#SearchContent").val('').trigger("change");
            var url = "@Html.Raw(Url.Action("_SearchSupplier", "Supplier", new { searchContent = "" }))";
            $('#saveDiv').load(url);
        });

        $("#close").click(function () {
            window.open('@Url.Action("Index", "Home")', "_self");
        });
    });

    function error_handler(e) {
        if (e.errors) {
            var message = "Errors:\n";
            $.each(e.errors, function (key, value) {
                if ('errors' in value) {
                    $.each(value.errors, function () {
                        message += this + "\n";
                    });
                }
            });
            alert(message);
        }
    }

    function sync_handler(e) {
        this.read();
    }
</script>
</head>
<div class="page-content">
        <table style="width:100%">
            <tr>
                <td>
                    <h2 class="pagetitle">Supplier List</h2>
                </td>
                <td align="right">
                    @Html.TextBox("SearchContent", "", new { @class = "k-textbox fa fa-search", @style = "width: 350px", @placeholder = HttpUtility.HtmlDecode("&#xf002;") + " Search By Supplier info" })
                </td>
                <td align="right" style="width:350px">
                    <input type="button" value="SEARCH" class="btn btn-primary" id="search" style="width:100px" />
                    <input type="button" value="CLEAR" class="btn btn-primary" id="clear" style="width:100px" />
                    <input type="button" value="BACK" class="btn btn-default" id="close" style="width:100px" />
                </td>
            </tr>
        </table>

    <hr />
    <div id="saveDiv">
        @{ Html.RenderAction("_SearchSupplier", new { searchContent = "" }); }
    </div>
</div>