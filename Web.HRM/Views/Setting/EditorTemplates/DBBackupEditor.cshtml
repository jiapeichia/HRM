@model Meo.Web.ViewModels.DBBackupViewModels

@{
    ViewBag.Title = "BackUp Path Editor";
}

<table style="width:100%">
    <tbody>
        <tr>
            <td>
                @Html.LabelFor(model => model.Path, new { @style = "width : 100px", @class = "control-label col-md-2" })
            </td>
            <td>
                @Html.EditorFor(model => model.Path)
                @Html.ValidationMessageFor(model => model.Path)
            </td>
        </tr>
    </tbody>
</table>
<style>
    .k-edit-form-container {
        position: relative;
        width: 100%;
    }

    .k-textbox {
        width: 350px;
    }
</style>