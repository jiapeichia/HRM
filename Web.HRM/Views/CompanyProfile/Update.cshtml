@model Meo.Web.ViewModels.CompanyProfile
@using Kendo.Mvc.UI;

@{
    ViewBag.Title = "Company Profile";
}

<head>
    <style>
        legend {
            padding: 0.2em 0.5em;
            color: grey;
            font-size: 130%;
        }

        fieldset {
            border: 1px solid grey;
            padding: 1em;
            font: 100%/1 sans-serif;
        }

        label {
            float: left;
            width: 25%;
            margin-right: 0.5em;
            padding-top: 0.2em;
            text-align: right;
            font-weight: bold;
        }

        td {
            padding: 5px;
        }

        .k-upload .k-upload-button {
            min-width: 7.167em;
            margin-right: 0em;
        }

        .k-dropzone {
            border-style: solid;
            border-width: 0;
            padding: .2em;
            background-color: white;
        }

        .k-dropdown, .k-textbox {
            /*width: 100%;*/
            max-width: 100%;
            width: 18.4em;
        }

        .k-textbox {
            width: 350px;
        }
    </style>
    <script>
    $(function () {
        $("#close").click(function () {
            window.open('@Url.Action("Preview", "CompanyProfile")', "_self");
        });
    });

    $("html, body").animate({
        scrollTop: 0
    }, 200);
    </script>
</head>
<div class="page-content">
    @using (Html.BeginForm("Update", "CompanyProfile", FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
    {
        <div align="right">
            <span style="padding-right:5px"><button id="update" data-bind="click: update" class="btn btn-primary" style="width:110px;padding:5px">UPDATE</button> </span>
            <input type="button" value="CANCEL" class="btn btn-default" id="close" style="width:100px" />
        </div>
        <br />
        @Html.HiddenFor(m => m.Id)
        <div class="sub-content" style="margin-top:0px">
            <div class="bar-title"><span>COMPANY PROFILE</span></div>
            <hr style="height:1px;border-width:0;color:gray;background-color:gray; margin:0px">
            <br />
            @Html.AntiForgeryToken()
            <table style="width:80%" align="center">
                <tr>
                    <td rowspan="9" width="10%" align="center">
                        <img src="@Url.Content("~/Images/Customer/" + Model.Logo)" padding="5px" width="110" @*height="130"*@ alt="" onerror="this.src='@Url.Content("~/Images/Employee/user.png")'" /><br>
                        @(Html.Kendo().Upload()
                            .Name("file")
                            .HtmlAttributes(new { accept = "image/*" }) // accept all image type
                            .Multiple(false)
                            )
                    </td>
                    <td rowspan="9" style="padding:5px; width:2%"></td>
                    <td style="width:5%">@Html.LabelFor(model => model.Name, new { @style = "width : 150px" })</td>
                    <td style="width:30%">
                        @Html.EditorFor(model => model.Name)
                        @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
                    </td>
                </tr>
                <tr>
                    <td>
                        @Html.LabelFor(model => model.RegNo, new { @style = "width : 150px" })
                    </td>
                    <td>
                        @Html.EditorFor(model => model.RegNo, new { @style = "width: 350px" })
                        @Html.ValidationMessageFor(model => model.RegNo, "", new { @class = "text-danger" })
                    </td>
                </tr>
                <tr>
                    <td style="width:5%">
                        @Html.LabelFor(model => model.Address1, new { @style = "width : 150px" })
                    </td>
                    <td style="width:30%">
                        @Html.EditorFor(model => model.Address1, new { @style = "width : 350px" })
                        @Html.ValidationMessageFor(model => model.Address1, "", new { @class = "text-danger" })
                    </td>
                </tr>
                <tr>
                    <td style="width:5%">
                        @Html.LabelFor(model => model.Address2, new { @style = "width : 150px" })
                    </td>
                    <td style="width:30%">
                        @Html.EditorFor(model => model.Address2, new { @style = "width : 350px" })
                        @Html.ValidationMessageFor(model => model.Address2, "", new { @class = "text-danger" })
                    </td>
                </tr>
                <tr>
                    <td>
                        @Html.LabelFor(model => model.Address3, new { @style = "width : 150px" })
                    </td>
                    <td>
                        @Html.EditorFor(model => model.Address3, new { @style = "width: 350px" })
                        @Html.ValidationMessageFor(model => model.Address3, "", new { @class = "text-danger" })
                    </td>
                </tr>
                <tr>
                    <td>
                        @Html.LabelFor(model => model.Tel, new { @style = "width : 150px" })
                    </td>
                    <td>
                        @Html.EditorFor(model => model.Tel, new { @style = "width: 350px" })
                        @Html.ValidationMessageFor(model => model.Tel, "", new { @class = "text-danger" })
                    </td>
                </tr>
                <tr>
                    <td>
                        @Html.LabelFor(model => model.Currency, new { @style = "width : 150px" })
                    </td>
                    <td>
                        @Html.EditorFor(model => model.Currency, new { @style = "width: 350px" })
                        @Html.ValidationMessageFor(model => model.Currency, "", new { @class = "text-danger" })
                    </td>
                </tr>
            </table>
        </div>
    }
</div>
