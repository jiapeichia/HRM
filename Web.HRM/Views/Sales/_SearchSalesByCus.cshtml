@model Meo.Web.ViewModels.SalesViewModels

<head>
    @section Scripts {
        @Scripts.Render("~/bundles/jqueryval")

        <script>
        function error_handler(e) {
            if (e.errors) {
                var message = "Errors:\n";
                $.each(e.errors, function (key, value) {
                    if ('errors' in value) {
                        $.each(value.errors, function () {
                            message += this + "\n";
                        });
                    }
                });
                alert(message);
            }
        }

        function sync_handler(e) {
            this.read();
        }

        $(".close-button").click(function () {
            window.open('@Url.Action("Index", "Home")', "_self");
            //window.close();
        });

        // --- collapse all group grid ---
        var collapseAllGroups = function (grid) {
            grid.table.find(".k-grouping-row").each(function () {
                grid.collapseGroup(this);
            });
        }

        //On the grid
        function dataBound() {
            collapseAllGroups(this);
        }
        </script>
    }
</head>

<div>
    @(Html.Kendo().Grid<Meo.Web.ViewModels.SalesViewModels>()
        .Name("GridForSales")
        .HtmlAttributes(new { style = "100%" })
        .Columns(columns =>
        {
            columns.Bound(c => c.CusId).ClientTemplate(
                @"<div class='small-photo'
            style='background-image: url(" + @Url.Content("~/Images/Customer/#:data.ImagePath#") + ");'></div><div class='customer-name'># #</div>").Width("120px");
            columns.Bound(c => c.SalesId);
            //columns.Bound(c => c.TypeId);
            columns.Bound(c => c.TotalAmt);
            columns.Bound(c => c.OrderDate);
            columns.Bound(c => c.PaymentDate);
            columns.Bound(c => c.Remarks);
            columns.Bound(c => c.Active).ClientTemplate(""
                + "# if (Active == false) { #"
                + "Active"
                + "# } else if (Active == true) { #"
                + "Inactive"
                + "# } else { #"
                + "# } #").Width("80px");
            //columns.ForeignKey(c => c.Mod_by, (System.Collections.IEnumerable)ViewData["Customer"], "Emp_id", "DisplayName").Title("Update By");
            columns.Bound(c => c.ModBy);
            columns.Bound(c => c.ModDate);
            //columns.Bound(c => c.SalesId).Title("").ClientTemplate("<a href='" + @Url.Action("SalesDetail", "Sales", new { id = "#=SalesId#" }) + "' ><span class='k-button k-button-icontext k-grid-edit'>Preview</span></a>").Width(90);
            //columns.Bound(c => c.SalesId).Title("").ClientTemplate("<a href='" + @Url.Action("UpdateCustomer", "Sales", new { id = "#=SalesId#" }) + "' ><span class='k-button k-button-icontext k-grid-edit'>Update</span></a>").Width(90);
            if (Session["RoleName"].Equals("Administrator"))
            {
                columns.Command(command => command.Destroy()).Width(90);
            }
        })
        .Sortable()
        .Pageable(pageable => pageable
        .Refresh(true).Messages(m => m.Refresh(string.Empty)))
        .ToolBar(toolbar => toolbar.Template("<a id='Create' class='k-button k-button-icontext k-add' href='" + @Url.Action("NewCustomer", "Customer") + "'style='float:right'> + Create New </a>"))
        .DataSource(source => source
        .Ajax()
        .PageSize(10)
        .Events(events => events.Error("error_handler").Sync("sync_handler"))
        .Sort(sort => sort.Add("OrderDate").Descending())
        .Model(model =>
        {
            model.Id(tc => tc.SalesId);
            model.Field(item => item.SalesId).Editable(false);
        })
        .Read(read => read.Action("Read_SalesByCus", "Sales", new { CusId = ViewBag.CusId }))
        .Destroy(update => update.Action("Destroy", "Sales"))
        )
        .Resizable(resize => resize.Columns(true))
        .NoRecords("No Records Found")
    )
</div>
