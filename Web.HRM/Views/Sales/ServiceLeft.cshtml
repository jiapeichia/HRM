@* Error msg to be shown & sync grid table automatically *@
<script type="text/javascript">
    function openEmployeeSelection(id, dueFlag, coursebal, course, salesId) {
        //if (salesId === undefined) {
        //    alert("SalesId is undefined!");
        //    return;
        //}

        if (dueFlag && (coursebal < course || coursebal == 1)) {
            $.ajax({
                url: '@Url.Action("PaymentCount", "GIROs")', // Your backend action to check payments
                type: 'GET',
                data: { salesId: salesId }, // Pass salesId or any necessary parameters
                success: function (response) {
                    if (response.count <= course - coursebal || coursebal == 1) {
                        var url = '@Url.Action("GIROSales", "GIROs")?salesId=' + salesId + '&isTopUp=' + false;
                        window.location.href = url; @* '@Url.Action("GIROSales", "GIROs")?salesId=' + salesId;*@
                        ////window.location.href = '@Url.Action("GIROSales", "GIROs")?salesId=' + salesId;
                    } else {
                        openServiceDialog(id, salesId);
                    }
                },
                error: function () {
                    alert("An error occurred while checking duplicate payments.");
                }
            });
        }
        @*if (dueFlag && coursebal < course) {
            // Redirect to another page if DueFlag is true
            window.location.href = '@Url.Action("GIROSales", "GIROs")?salesId=' + salesId;
        }*@
        else {
            openServiceDialog(id, salesId);
        }
    }

    // Extracted function to handle the "else" block logic
    function openServiceDialog(id, salesId) {
    var dialog = $("#employeeSelection").kendoWindow({
        title: "Service Information",
        modal: true,
        width: 650
    }).data("kendoWindow");

    dialog.center();
    dialog.open();

    // Create a closure to capture the 'id'
    (function () {
        var capturedId = id;

        // Attach a click event to the "PROCEED" button in the dialog
        $("#updateServicePIC").off("click").on("click", function () { // Use `off` to avoid multiple bindings
            var picid = $("#EmployeeDropdown").data("kendoDropDownList").value();
            var picid2 = $("#picid2").data("kendoDropDownList").value();
            var picid3 = $("#picid3").data("kendoDropDownList").value();
            var picName = $("#EmployeeDropdown").data("kendoDropDownList").text();
            var pic2Name = $("#picid2").data("kendoDropDownList").text();
            var pic3Name = picid3 !== "" ? $("#picid3").data("kendoDropDownList").text() : "";
            var remarks = $("#Remarks").val();

            if (picid === "" && picid2 === "" && picid3 === "") {
                return alert("\nPlease select at least one PIC! \n");
            } else if (
                (picid !== "" && picid === picid2) ||
                (picid !== "" && picid === picid3) ||
                (picid2 !== "" && picid === picid2) ||
                (picid2 !== "" && picid2 === picid3) ||
                (picid3 !== "" && picid2 === picid3)
            ) {
                return alert("\nNo duplicate PIC allowed! \n");
            }

            $.ajax({
                type: "POST",
                url: '@Url.Action("Update_Service", "Sales")',
                data: {
                    id: capturedId,
                    picid: picid,
                    picid2: picid2,
                    picid3: picid3,
                    picname: picName,
                    pic2name: pic2Name,
                    pic3name: pic3Name,
                    remarks: remarks,
                },
                success: function (response) {
                    refreshGrids();

                    var url = '@Url.Action("ServiceReceipt", "Receipt")' + '?id=' + response.data.Id + '&response.data.SalesId=' + salesId;
                    window.open(url, '_blank');
                }
            });

            // Close the dialog
            dialog.close();
        });
        })();

        // Function to refresh both grids
        function refreshGrids() {
            var gridForService = $("#GridForService").data("kendoGrid");
            if (gridForService) {
                gridForService.dataSource.read();
            }

            var gridForServicehistory = $("#GridForServicehistory").data("kendoGrid");
            if (gridForServicehistory) {
                gridForServicehistory.dataSource.read();
            }
        }

}
</script>
