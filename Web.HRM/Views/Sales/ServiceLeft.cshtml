@using Meo.Web.ViewModels
@using Kendo.Mvc.UI

@{
    ViewBag.Title = "Service Left";
}

<head>
    <style>
        /* red flag */
        .payment-required {
            display: inline-block;
            background-color: #f44336; /* Softer red for warning */
            color: white; /* Text color for contrast */
            font-size: 13px; /* Smaller and neat font */
            font-weight: bold; /* Make it stand out */
            padding: 5px 10px; /* Add spacing inside the box */
            border-radius: 5px; /* Rounded corners */
            box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.2); /* Subtle shadow for depth */
            text-transform: uppercase; /* Optional: Make text uppercase */
            cursor: pointer;
        }

        .warning {
            display: inline-block;
            background-color: orange; /* Softer red for warning */
            color: white; /* Text color for contrast */
            font-size: 13px; /* Smaller and neat font */
            font-weight: bold; /* Make it stand out */
            padding: 5px 10px; /* Add spacing inside the box */
            border-radius: 5px; /* Rounded corners */
            box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.2); /* Subtle shadow for depth */
            text-transform: uppercase; /* Optional: Make text uppercase */
            cursor: pointer;
        }

        .payment-box:hover {
            opacity: 0.9; /* Slightly dim the box when hovered */
        }

        /* green count */
        .green-count {
            background-color: green;
            width: 25px;
            height: 25px;
            border-radius: 50%;
            text-align: center;
            color: white;
            font-weight: bold;
            box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.2);
        }
    </style>
</head>

@(Html.Kendo().Grid<Service>()
        .Name("GridForService")
        .HtmlAttributes("100%")
        .Columns(columns =>
        {
            columns.Bound(c => c.SalesId).Width("110px")
            .ClientTemplate("# if (DueFlag == false) { #" + "#=SalesId#" +
            "# } else if (FreeService == true) { #" + "<span class='warning' title=\"Pending Full Payment\">#=SalesId#</span>" +
            "# } else if (DueFlag == true) { #" + "<span class='payment-required' title=\"Payment Required\">#=SalesId#</span>" +
            "# } else { #" + "# } #");
            columns.Bound(c => c.ServiceName);
            columns.Bound(c => c.Remarks);
            columns.Bound(c => c.CourseBal).Width("30px").ClientTemplate("<div class='green-count'>#=CourseBal#</div>");
            columns.Bound(c => c.Course).Width("30px");
            columns.Bound(c => c.PurchaseDate).Width("180px");
            columns.Bound(c => c.ExpiryDate).Width("100px");

            //.ClientTemplate("# if (FreeService == false || FreeService == true && DueFlag == false) { #" +
            //            "<a href='javascript:void(0)' class='k-button k-button-icontext k-grid-edit' " +
            //            "onclick='openEmployeeSelection(#=Id#, #=DueFlag#, #=CourseBal#, #=Course#, \"#=SalesId#\")'>PROCEED</a>" +
            //            "# } else { #" +
            //            "<a href='javascript:void(0)' class='k-button k-button-icontext k-grid-edit disabled' " +
            //            "title='Full payment required'>PROCEED</a>" +
            //            "# } #").Width(100);

            columns.Bound(c => c.SalesId).Title("")
            .ClientTemplate("# if (FreeService == false || FreeService == true && DueFlag == false) { #" +
                        "<a href='javascript:void(0)' class='k-button k-button-icontext k-grid-edit' " +
                        "onclick='openEmployeeSelection(#=Id#, #=DueFlag#, #=CourseBal#, #=Course#, \"#=SalesId#\")'>PROCEED</a>" +
                        "# } else { #" +
                        "<a href='javascript:void(0)' class='k-button k-button-icontext k-grid-edit disabled' " +
                        "title='Full payment required'>PROCEED</a>" +
                        "# } #").Width(100);
            columns.Bound(c => c.SalesId).Title("")
            .ClientTemplate("# if (FreeService == false && DueFlag == true) { #" +
                        "<a href='javascript:void(0)' class='k-button k-button-icontext k-grid-edit' " +
                        "onclick='openServiceDialog(#=Id#, \"#=SalesId#\")'>SKIP</a>" +
                        "# } #").Width(80);
            //.ClientTemplate("<a href='javascript:void(0)' class='k-button k-button-icontext k-grid-edit' onclick='openEmployeeSelection(#=Id#, #=DueFlag#, #=CourseBal#, #=Course#, \"#=SalesId#\")'>PROCEED</a>").Width(100);
        })
        .Pageable(pageable => pageable
        .Refresh(true).Messages(m => m.Refresh(string.Empty)))
        .DataSource(dataSource => dataSource
        .Ajax()
        .PageSize(10)
        .Events(events => events.Error("error_handler").Sync("sync_handler").RequestEnd("onRequestEnd"))
        .ServerOperation(true)
        .Read(read => read.Action("Read_Service", "Sales", new { cusid = @ViewBag.CusId }))
        .Update(update => update.Action("Update_SalesItem", "Sales"))
        .Sort(sort =>
        {
            sort.Add(c => c.PurchaseDate).Descending();
        })
        .Model(model =>
        {
            model.Id(e => e.Id);
        }))
        .Resizable(resize => resize.Columns(true))
        .NoRecords("No Records Found"))

<span id="notification" style="display:none;"></span>

<div id="employeeSelection" style="display: none;">
    <p>Select a PIC:</p>
